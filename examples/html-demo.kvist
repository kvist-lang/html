;; Contextual Data literals make inline Hiccup ordinary typed Kvist.
(package main)
(import h "..")

(defn html-demo [] -> bool
  (let [page (h.render
               [:div {:class "border" :onclick "alert('hello!')"}
                [:button {:class "primary"} "Save"]
                [:ul [:li 1] [:li 2] [:li 3]]]) :defer]
    (println page)
    true))

(defn main []
  (html-demo))
