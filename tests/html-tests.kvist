(package tests)
(import t "kvist:test")
(import html "..")

(t.deftest renders-contextual-data-and-escapes-html
  (let [title "A&B"
        rendered (html.render
                   [:div {:class "panel"}
                    [:span title]]) :defer]
    (t.is (= rendered
             "<div class=\"panel\"><span>A&amp;B</span></div>"))))

(t.deftest renders-tag-id-and-class-shorthand
  (let [rendered (html.render
                   [:div#daily-report-configuration.my-class "Report"]) :defer]
    (t.is (= rendered
             "<div id=\"daily-report-configuration\" class=\"my-class\">Report</div>"))))

(t.deftest renders-multiple-shorthand-classes
  (let [rendered (html.render
                   [:section.report.daily "Ready"]) :defer]
    (t.is (= rendered
             "<section class=\"report daily\">Ready</section>"))))

(t.deftest explicit-id-and-class-attributes-override-shorthand
  (let [tree '[:div#shorthand-id.shorthand-class
               {:id "explicit-id" :class "explicit-class"}]
        rendered (html.render tree) :defer]
    (t.is (= rendered
             "<div id=\"explicit-id\" class=\"explicit-class\"></div>"))))

(t.deftest supports-shorthand-on-void-elements
  (let [rendered (html.render
                   [:input#search-field.form-control]) :defer]
    (t.is (= rendered
             "<input id=\"search-field\" class=\"form-control\">"))))

(t.deftest rejects-invalid-tag-shorthand
  (let [[rendered error ok] (html.try-render-data '[:div.bad#id])
        _ rendered]
    (t.is (not ok))
    (t.is (= error.message
             "HTML tag shorthand must use :tag#id.class syntax with non-empty parts"))))

(t.deftest renders-punctuated-keyword-attribute-names
  (let [rendered (html.render
                   [:form {:data-on:submit__prevent "@post('/capture')"
                           :aria-label "Capture"}
                    [:input {:data-bind "captureTitle"}]]) :defer]
    (t.is (= rendered
             "<form data-on:submit__prevent=\"@post(&#39;/capture&#39;)\" aria-label=\"Capture\"><input data-bind=\"captureTitle\"></form>"))))

(t.deftest renders-existing-data-through-the-same-overload
  (let [tree '[:article {:class "card"} [:h1 "Stored"]]
        rendered (html.render tree) :defer]
    (t.is (= rendered
             "<article class=\"card\"><h1>Stored</h1></article>"))))

(t.deftest renders-conditional-contextual-data
  (let [ready? true
        rendered (html.render
                   [:section
                    (if ready?
                      [:p "Ready"]
                      nil)]) :defer]
    (t.is (= rendered "<section><p>Ready</p></section>"))))

(t.deftest renders-keyword-fragments
  (let [rendered (html.render
                   [:<>
                    [:h2 "One"]
                    [:h2 "Two"]]) :defer]
    (t.is (= rendered "<h2>One</h2><h2>Two</h2>"))))

(t.deftest renders-complete-document
  (let [rendered (html.render-document
                   [:html {:lang "en"}
                    [:head [:title "Kvist"]]
                    [:body {:data-on:load "@get('/ready')"}
                     [:main "Ready"]]]) :defer]
    (t.is (= rendered
             "<!doctype html><html lang=\"en\"><head><title>Kvist</title></head><body data-on:load=\"@get(&#39;/ready&#39;)\"><main>Ready</main></body></html>"))))

(t.deftest rejects-non-keyword-tags
  (let [[rendered error ok] (html.try-render-data '[div "No"])
        _ rendered]
    (t.is (not ok))
    (t.is (= error.message "HTML tags must be non-empty keywords"))))

(t.deftest renders-string-input-as-escaped-text
  (let [rendered (html.render "A&B <ok>") :defer]
    (t.is (= rendered "A&amp;B &lt;ok&gt;"))))

(t.deftest renders-data-template-bindings
  (let [name "Ada"
        rendered (html.template
                   "<p>{{name}}</p>"
                   {:name name}) :defer]
    (t.is (= rendered "<p>Ada</p>"))))
